def score_mechanisms(answers):
s = {“I”: 0, “C”: 0, “R”: 0, “T”: 0}
for i, a in answers.items():
if a:
for (opt, m) in SCENARIOS[i][“opts”]:
if a == opt:
s[m] += 1
return s

def ranked(scores, reverse=True):
return [m for m, _ in sorted(scores.items(), key=lambda x: x[1], reverse=reverse)]

def score_label(v, total=12):
pct = v / total
if pct >= 0.35:   return “Dominant”,  “#6D28D9”
if pct >= 0.22:   return “Preferred”, “#2563EB”
if pct >= 0.10:   return “Emerging”,  “#10B981”
return “Latent”,  “#94A3B8”

