def make_radar(all_scores: list, labels: list, title=“Boundary Compass Profile”):
keys = [“I”, “C”, “R”, “T”]
names = [MECH_META[k][“name”] for k in keys]
palette = [”#2563EB”, “#F59E0B”, “#10B981”, “#8B5CF6”, “#EF4444”]

```
fig = go.Figure()
for idx, scores in enumerate(all_scores):
    vals = [scores[k] for k in keys] + [scores[keys[0]]]
    theta = names + [names[0]]
    c = palette[idx % len(palette)]
    r, g, b = int(c[1:3], 16), int(c[3:5], 16), int(c[5:7], 16)
    fig.add_trace(go.Scatterpolar(
        r=vals, theta=theta, fill="toself",
        fillcolor=f"rgba({r},{g},{b},0.13)",
        line=dict(color=c, width=2.5),
        name=labels[idx],
    ))

fig.update_layout(
    polar=dict(
        bgcolor="rgba(248,250,252,0.9)",
        radialaxis=dict(
            visible=True, range=[0, 12],
            tickvals=[3, 6, 9, 12],
            tickfont=dict(size=10, color="#94A3B8"),
            gridcolor="rgba(148,163,184,0.25)",
            linecolor="rgba(148,163,184,0.25)",
        ),
        angularaxis=dict(
            gridcolor="rgba(148,163,184,0.2)",
            tickfont=dict(size=12, color="#334155"),
        ),
    ),
    showlegend=len(all_scores) > 1,
    legend=dict(font=dict(size=11)),
    title=dict(text=title, font=dict(size=14, color="#1E293B", family="Georgia,serif"), x=0.5),
    paper_bgcolor="white", plot_bgcolor="white",
    height=380, margin=dict(t=60, b=10, l=20, r=20),
)
return fig
```

def make_bar(scores):
keys = [“I”, “C”, “R”, “T”]
colors = [MECH_META[k][“color”] for k in keys]
names = [f”{MECH_META[k][‘icon’]} {MECH_META[k][‘name’]}” for k in keys]
vals = [scores[k] for k in keys]

```
fig = go.Figure(go.Bar(
    x=vals, y=names, orientation="h",
    marker=dict(color=colors, line=dict(width=0)),
    text=[str(v) for v in vals],
    textposition="outside",
    textfont=dict(size=13, color="#1E293B", family="DM Sans, sans-serif"),
))
fig.update_layout(
    height=220,
    xaxis=dict(range=[0, 14], showgrid=True, gridcolor="#E2E8F0",
               tickfont=dict(color="#94A3B8", size=10), zeroline=False),
    yaxis=dict(tickfont=dict(size=12, color="#334155")),
    paper_bgcolor="white", plot_bgcolor="white",
    margin=dict(t=10, b=10, l=10, r=40),
    showlegend=False,
)
return fig
```

